{
  "name": "4626-ajna-keeper",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "test:ark:unit": "VITEST_SUITE=ark-unit vitest run --config vitest.config.ts",
    "test:ark:integration": "VITEST_SUITE=ark-integration INTEGRATION=true vitest run --config vitest.config.ts",
    "test:ark": "pnpm run test:ark:unit && pnpm run test:ark:integration",
    "test:metavault:unit": "VITEST_SUITE=metavault-unit METAVAULT=true vitest run --config vitest.config.ts",
    "test:metavault:integration": "VITEST_SUITE=metavault-integration METAVAULT=true vitest run --config vitest.config.ts",
    "test:metavault": "VITEST_SUITE=metavault METAVAULT=true vitest run --config vitest.config.ts",
    "test:property": "VITEST_SUITE=property vitest run --config vitest.config.ts",
    "test": "pnpm run test:ark && pnpm run test:metavault && pnpm run test:property",
    "format": "prettier --write \"src/**/*.{ts,js}\" \"test/**/*.{ts,js}\"",
    "build": "tsc -p tsconfig.build.json",
    "build:tools": "tsc -p tsconfig.tools.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint --ext .ts,.js src",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "precommit": "pnpm format && pnpm typecheck && pnpm lint && pnpm test",
    "docker:build": "docker build -t ajna-erc4626-keeper .",
    "docker:run": "docker run --rm --env-file .env -v \"$PWD/config.json:/app/config.json:ro\" ajna-erc4626-keeper",
    "import-key": "pnpm run build:tools && node dist-tools/scripts/import-key.js"
  },
  "dependencies": {
    "dotenv": "17.2.1",
    "graphql-request": "7.2.0",
    "pino": "9.7.0",
    "undici": "7.25.0",
    "viem": "2.33.2"
  },
  "devDependencies": {
    "@eslint/js": "9.32.0",
    "@types/node": "24.2.0",
    "@typescript-eslint/eslint-plugin": "8.39.0",
    "@typescript-eslint/parser": "8.39.0",
    "eslint": "9.32.0",
    "eslint-config-prettier": "10.1.8",
    "fast-check": "^3.23.2",
    "globals": "16.3.0",
    "prettier": "3.6.2",
    "tsx": "4.20.3",
    "typescript": "5.9.2",
    "vitest": "3.2.4"
  }
}
