# Required secrets
RPC_URL=https...
SUBGRAPH_URL=https...

# Optional: override the runtime config file path.
# Defaults to ./config.json in the current working directory.
# CONFIG_PATH=/app/config.json

# Configure exactly ONE credential mode.
#
# Mode 1: Raw private key.
# Headless fallback for deployments that source the key from a secret manager.
# PRIVATE_KEY=0xabc...
#
# Mode 2: Local V3 keystore file.
# Recommended for local use (startup prompts for the password).
# Generate one with: pnpm run import-key
# KEYSTORE_PATH=./keystore/keeper-key.json
#
# Mode 3: Remote signer.
# Preferred production posture where available. The keeper expects a Web3Signer-compatible
# JSON-RPC endpoint and signs with the configured externally managed EOA. The URL must use
# https; http is rejected unless REMOTE_SIGNER_ALLOW_INSECURE is set to the literal string
# 'true' (intended for local testing only; emits a startup warning).
# REMOTE_SIGNER_URL=https://web3signer.internal:8545
# REMOTE_SIGNER_ADDRESS=0x0000000000000000000000000000000000000000
# REMOTE_SIGNER_ALLOW_INSECURE=true
#
# Optional bearer token sent as 'Authorization: Bearer <token>' on every signer request.
# Useful when an auth-terminating proxy (or the signer itself) requires a token or API key.
# REMOTE_SIGNER_AUTH_TOKEN=eyJhbGciOi...
#
# Optional mTLS material for the keeper to authenticate to the signer with a client certificate.
# This is the standard production posture for Web3Signer. CERT and KEY must be set together.
# All paths point to PEM files. KEY_PASSWORD is only required when the key is encrypted. CA is
# optional and used to verify the signer's server certificate when it is issued by a private CA.
# REMOTE_SIGNER_TLS_CLIENT_CERT=/etc/keeper/tls/client.pem
# REMOTE_SIGNER_TLS_CLIENT_KEY=/etc/keeper/tls/client.key
# REMOTE_SIGNER_TLS_CLIENT_KEY_PASSWORD=...
# REMOTE_SIGNER_TLS_CA=/etc/keeper/tls/ca.pem

# A CoinGecko API key is not strictly required for the rate of queries made by this keeper.
#
# If a key is defined, the tier is also required, since the header is different for each request (demo or pro).
# If a key is not defined, the tier is not required.
ORACLE_API_KEY=CG-...
ORACLE_API_TIER=demo

# Optional: the test suite is designed to fork mainnet state.
# Since the RPC defined here may refer to any chain, the test suite needs a mainnet RPC for set up.
# By default, the test suite uses the free node at 'https://eth.drpc.org', but this node is rate-limited, which may cause unexpected test failures.
# To avoid this, another RPC can be defined here.
MAINNET_RPC_URL=https...
